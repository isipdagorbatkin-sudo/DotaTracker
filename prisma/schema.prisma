generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  steamId       String   @unique
  name          String?
  avatar        String?
  mmr           Int      @default(0)
  rank          Int      @default(0)
  rankName      String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  accounts      Account[]
  sessions      Session[]
  mmrHistory    MMRHistory[]
  matches       Match[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model MMRHistory {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  mmr       Int
  change    Int
  date      DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mmr_history")
}

model Match {
  id          String   @id @default(cuid())
  matchId     BigInt   @map("match_id")
  userId      String   @map("user_id")
  heroId      Int      @map("hero_id")
  heroName    String   @map("hero_name")
  kills       Int      @default(0)
  deaths      Int      @default(0)
  assists     Int      @default(0)
  win         Boolean
  duration    Int      @default(0)
  gpm         Int      @default(0)
  xpm         Int      @default(0)
  heroDamage  Int      @default(0) @map("hero_damage")
  towerDamage Int      @default(0) @map("tower_damage")
  healing     Int      @default(0)
  gameMode    Int      @default(0) @map("game_mode")
  lobbyType   Int      @default(0) @map("lobby_type")
  date        DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("matches")
}
